# Database
DATABASE_URL="postgresql://school_erp:school_erp_pass@localhost:5432/school_erp"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development

# Email (Resend)
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="noreply@yourschool.edu.np"

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="school-erp"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# Payment Gateways
ESEWA_SECRET_KEY="your_esewa_key"
ESEWA_PRODUCT_CODE="your_product_code"
KHALTI_SECRET_KEY="your_khalti_secret"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
