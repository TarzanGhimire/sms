# Backend production environment (Render sets these via the dashboard / render.yaml).
# Only these are required for the free deployment (no email/SMS/payments yet).

# Neon Postgres connection string (Dashboard -> Connection Details -> Pooled).
# Must include ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Strong random secrets (Render's render.yaml auto-generates these).
# To make your own:  openssl rand -base64 48
JWT_SECRET="change-me-strong-random"
JWT_REFRESH_SECRET="change-me-another-strong-random"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Your Vercel frontend URL(s), comma-separated, NO trailing slash.
FRONTEND_URL="https://your-app.vercel.app"

NODE_ENV="production"
# PORT is provided automatically by Render — do not set it.

# ── Not needed for the free deploy (leave unset) ──
# RESEND_API_KEY=        # email (disabled for now)
# R2_*                   # file uploads (disabled for now)
# ESEWA_* / KHALTI_*     # live payments (disabled for now)
